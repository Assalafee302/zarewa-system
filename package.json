{
  "name": "zarewa-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:stack": "node scripts/dev-stack.mjs",
    "server": "node server/index.js",
    "start": "node server/index.js",
    "db:migrate": "node scripts/db-migrate.mjs",
    "pg:migrate": "node scripts/pg-migrate.mjs",
    "pg:import:sqlite": "node scripts/sqlite-to-postgres.mjs --truncate",
    "db:wipe": "node scripts/wipe-local-sqlite.mjs",
    "wipe:e2e-db": "node scripts/wipe-playwright-e2e.mjs",
    "db:wipe-empty-client": "node scripts/wipe-empty-client.mjs",
    "db:legacy-demo": "node server/applyLegacyDemoPackCli.js",
    "build": "vite build",
    "build:serve:lan": "npm run build && node scripts/serve-built-lan.mjs",
    "lint": "eslint .",
    "test": "vitest run -c vitest.config.js",
    "test:watch": "vitest -c vitest.config.js",
    "test:e2e": "playwright test",
    "test:e2e:sales-refund-finance": "playwright test e2e/sales-refund-finance-checklist.spec.js",
    "test:e2e:refund-risk": "playwright test e2e/refund-risk-api.spec.js",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e",
    "test:transactions": "vitest run -c vitest.config.js server/scenarioMatrix.test.js server/transactionalScenarios.test.js",
    "test:operations": "vitest run -c vitest.config.js server/inventoryScenarios.test.js server/accessoryFulfillment.test.js server/transactionalScenarios.test.js",
    "test:financial": "vitest run -c vitest.config.js server/refundSecurity.test.js server/refundE2E.test.js server/accountingPhase2.test.js server/accountingStatementsOps.test.js server/api.test.js",
    "test:critical-workflows": "vitest run -c vitest.config.js src/lib/moduleAccess.test.js src/lib/accountCore.test.js src/lib/managerDashboardCore.test.js src/lib/salesStockCore.test.js server/ensureLegacyDemoPack.test.js server/refundSecurity.test.js server/refundE2E.test.js server/accountingPhase2.test.js server/api.test.js",
    "test:ops-finance": "npm run test:operations && npm run test:financial",
    "test:e2e:operations": "playwright test e2e/complete-gate.spec.js --grep \"operations: Store\"",
    "test:e2e:production": "playwright test e2e/complete-gate.spec.js e2e/production-register.spec.js --grep \"Store & production|Production register\"",
    "test:e2e:finance": "playwright test e2e/complete-gate.spec.js --grep \"finance manager\"",
    "test:e2e:ops-finance": "playwright test e2e/complete-gate.spec.js --grep \"finance manager|operations: Store\"",
    "verify:ci": "npm run lint && npm run build && npm run test:transactions",
    "verify:complete": "node scripts/verify-complete.mjs",
    "preview": "vite preview",
    "hr:import-staff": "node server/importZarewaStaffFromXlsx.js",
    "import:access-sales": "node server/importAccessSalesPack.mjs",
    "import:access-staging": "node scripts/staging-import-access.mjs",
    "import:validate": "node scripts/validate-access-import.mjs",
    "import:merge-report": "node server/importAccessSalesPack.mjs --customer-merge-report",
    "import:legacy-branch": "node scripts/reassign-legacy-import-branch.mjs",
    "import:legacy-treasury": "node scripts/backfill-legacy-receipt-treasury.mjs",
    "import:access-finance": "node server/importAccessFinancePack.mjs",
    "stress:api": "node scripts/stress-api.mjs",
    "stress:lifecycle": "node scripts/fifty-lifecycle-stress.mjs",
    "stress:qa-mega": "node scripts/qa-operations-mega.mjs",
    "stress:qa-mega-lite": "node scripts/qa-mega-lite.mjs",
    "stress:finance100": "node scripts/finance-stress-100.mjs",
    "bench:dashboard": "node scripts/bench-dashboard-summary.mjs",
    "retention:prune": "node scripts/retention-prune.mjs"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "recharts": "^2.15.4",
    "synckit": "^0.11.12",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "supertest": "^7.2.2",
    "vitest": "3.2.4"
  }
}
