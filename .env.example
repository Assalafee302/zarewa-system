# Copy to `.env` (never commit `.env`). Zarewa requires PostgreSQL.

# --- Required (API + tests that hit the DB) ---
# Use Supabase "Session" or "Transaction" pooler URI in production when recommended.
# Example: postgres://USER:PASSWORD@HOST:6543/postgres?sslmode=require
DATABASE_URL=

# Alternative to DATABASE_URL (leave DATABASE_URL unset if you use these):
# PGHOST=aws-1-eu-north-1.pooler.supabase.com
# PGPORT=6543
# PGUSER=postgres.yourprojectref
# PGDATABASE=postgres
# PGPASSWORD=your-database-password

# --- HTTP ---
PORT=8787
# Render / containers: listen on all interfaces
ZAREWA_LISTEN_HOST=0.0.0.0

# --- Production cookies / CORS ---
NODE_ENV=development
COOKIE_SECURE=0
# Comma-separated origins for the SPA (no spaces). Production on Render: include every
# Vercel URL users hit (production + preview), e.g. https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# --- Frontend (Vercel production): leave unset so the browser calls same-origin `/api/...` ---
# VITE_API_BASE=

# --- Optional: AI assistant ---
# ZAREWA_AI_API_KEY=
# OPENAI_API_KEY=
# ZAREWA_AI_BASE_URL=https://api.openai.com/v1
# ZAREWA_AI_MODEL=gpt-4o-mini

# --- Optional: CSP override ---
# ZAREWA_CSP=

# --- Playwright / E2E (when not using defaults) ---
# E2E_UI_PORT=5180
# E2E_API_PORT=8788
# E2E_REUSE_SERVER=1

# --- Tests / seeding ---
# ZAREWA_EMPTY_SEED=1
# ZAREWA_TEST_ENFORCE_CSRF=1
# ZAREWA_TEST_SKIP_RATE_LIMIT=1
