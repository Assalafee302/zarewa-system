# Copy to .env in the app root (or let setup-ubuntu.sh create it).
# Do not commit .env.

NODE_ENV=production
PORT=8787
ZAREWA_DB=/var/lib/zarewa/zarewa.sqlite

# Exact origin users use in the browser (no trailing slash).
# Examples: https://zarewa.example.com  or  http://12.34.56.78
CORS_ORIGIN=https://zarewa.example.com

# 1 = HTTPS. 0 = HTTP (IP-only trial); required so cookies work without TLS.
COOKIE_SECURE=1
